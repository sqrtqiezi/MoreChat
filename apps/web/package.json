{
  "name": "@morechat/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:cucumber": "NODE_OPTIONS='--import tsx' cucumber-js",
    "test:cucumber:parallel": "NODE_OPTIONS='--import tsx' cucumber-js --parallel 4",
    "test:cucumber:smoke": "NODE_OPTIONS='--import tsx' cucumber-js --tags @smoke",
    "test:cucumber:debug": "HEADLESS=false NODE_OPTIONS='--import tsx' cucumber-js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@morechat/ui": "workspace:*",
    "@tanstack/react-query": "^5.45.1",
    "@tanstack/react-virtual": "^3.13.21",
    "axios": "^1.7.2",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-router-dom": "^7.13.1",
    "yet-another-react-lightbox": "^3.29.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@morechat/types": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cucumber-html-reporter": "^7.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.1",
    "vitest": "^2.1.9"
  }
}
