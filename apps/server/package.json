{
  "name": "@morechat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext ts",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:backfill:hot": "node scripts/backfill-missing-hot-messages.js",
    "db:seed": "tsx scripts/seed-test-data.ts",
    "db:cleanup:member-only-contacts": "node scripts/cleanup-member-only-contacts.js",
    "hash-password": "tsx scripts/hash-password.ts",
    "migrate:fts": "tsx scripts/migrate-fts.ts",
    "migrate:vectors": "tsx scripts/migrate-vectors.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.4.4-r.3",
    "@hono/node-server": "^1.11.4",
    "@huggingface/transformers": "^4.2.0",
    "@morechat/types": "workspace:*",
    "@prisma/client": "^5.0.0",
    "ali-oss": "^6.23.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.4.2",
    "hono": "^4.4.9",
    "hyparquet": "^1.25.1",
    "hyparquet-writer": "^0.13.0",
    "nodejieba": "^3.5.8",
    "p-queue": "^9.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.0.0",
    "sharp": "^0.34.5",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18"
  }
}
