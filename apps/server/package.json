{
  "name": "@morechat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext ts",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed-test-data.ts",
    "hash-password": "tsx scripts/hash-password.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.4",
    "@morechat/types": "workspace:*",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "hono": "^4.4.9",
    "prisma": "^5.0.0",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18"
  }
}
