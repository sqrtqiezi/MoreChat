# Database
DATABASE_URL="file:../data/morechat.db"

# Data Lake
DATA_LAKE_TYPE="filesystem"
DATA_LAKE_PATH="./data/lake"

# Server
PORT=3100
NODE_ENV="development"

# juhexbot API (测试环境可以使用 mock 数据)
JUHEXBOT_API_URL="http://chat-api.juhebot.com/open/GuidRequest"
JUHEXBOT_APP_KEY="test-app-key"
JUHEXBOT_APP_SECRET="test-app-secret"
JUHEXBOT_CLIENT_GUID="test-client-guid"

# Auth (测试密码: test123)
AUTH_PASSWORD_HASH="$2b$10$5O4obTEevX9o1ETjJdSab.VE7wuPc6bSE61SkesF0JjbzhWXHrCGC"
AUTH_JWT_SECRET="dev-jwt-secret-change-in-production"

# Cloud API
JUHEXBOT_CLOUD_API_URL="http://localhost:35789"

# Alicloud OSS (测试环境可以不配置)
ALICLOUD_OSS_REGION="oss-cn-hangzhou"
ALICLOUD_OSS_BUCKET="test-bucket"
ALICLOUD_OSS_ACCESS_KEY_ID="test-key"
ALICLOUD_OSS_ACCESS_KEY_SECRET="test-secret"
ALICLOUD_OSS_ENDPOINT="oss-cn-hangzhou.aliyuncs.com"

# Embedding (测试环境禁用)
EMBEDDING_ENABLED=false

# LLM (测试环境可选)
# LLM_BASE_URL=""
# LLM_API_KEY=""
# LLM_MODEL=""
